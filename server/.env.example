# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# Auth — use a long random string in production (64+ chars recommended)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Admin credentials (used only when running npm run seed)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=change_this_secure_password

# CORS — comma-separated list of allowed frontend origins
# Development: http://localhost:5173
# Production:  https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:5173
